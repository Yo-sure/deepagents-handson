{
  "name": "Mail Check Agent",
  "description": "메일함을 확인하고 중요 메일을 감지하는 Agent입니다. 중요 메일 발견 시 Notify Agent에게 A2A로 알림을 요청합니다.",
  "version": "1.0.0",
  "supportedInterfaces": [
    {"url": "http://localhost:9501", "protocolBinding": "JSONRPC", "protocolVersion": "1.0"}
  ],
  "capabilities": {
    "streaming": false
  },
  "skills": [
    {
      "id": "check-mail",
      "name": "메일 확인",
